<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.8">
<model name="vineyard_mower">

  <!-- ============================================================ -->
  <!-- base_link: chassis center, origin at ground-plane projection  -->
  <!-- ============================================================ -->
  <link name="base_link">
    <pose>0 0 0  0 0 0</pose>

    <inertial>
      <pose>0 0 0.35  0 0 0</pose>
      <mass>250.0</mass>
      <inertia>
        <!-- Box 1.2x0.8x0.4: Ixx = m/12*(y^2+z^2), Iyy = m/12*(x^2+z^2), Izz = m/12*(x^2+y^2) -->
        <ixx>16.667</ixx>
        <ixy>0.0</ixy>
        <ixz>0.0</ixz>
        <iyy>33.333</iyy>
        <iyz>0.0</iyz>
        <izz>43.333</izz>
      </inertia>
    </inertial>

    <visual name="chassis_visual">
      <pose>0 0 0.35  0 0 0</pose>
      <geometry>
        <box>
          <size>1.2 0.8 0.4</size>
        </box>
      </geometry>
      <material>
        <ambient>0.2 0.5 0.1 1</ambient>
        <diffuse>0.3 0.7 0.2 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>

    <collision name="chassis_collision">
      <pose>0 0 0.35  0 0 0</pose>
      <geometry>
        <box>
          <size>1.2 0.8 0.4</size>
        </box>
      </geometry>
    </collision>
  </link>

  <!-- front left wheel -->
  <link name="left_front_wheel">
    <pose>0 0 0  1.5708 0 0</pose>
    <inertial>
      <mass>2.0</mass>
      <inertia>
        <ixx>0.0225</ixx>   <!-- around rotation axis = 1/2*m*r² -->
        <ixy>0.0</ixy>
        <ixz>0.0</ixz>
        <iyy>0.0119</iyy>   <!-- transverse = 1/12*m*(3r²+L²) -->
        <iyz>0.0</iyz>
        <izz>0.0119</izz>
      </inertia>
    </inertial>
    <visual name="lf_wheel_visual">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.15 0.15 0.15 1</diffuse>
      </material>
    </visual>
    <collision name="lf_wheel_collision">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <!-- rear left wheel -->
  <link name="left_rear_wheel">
    <pose>0 0 0  1.5708 0 0</pose>
    <inertial>
      <mass>2.0</mass>
      <inertia>
        <ixx>0.0225</ixx>   <!-- around rotation axis = 1/2*m*r² -->
        <ixy>0.0</ixy>
        <ixz>0.0</ixz>
        <iyy>0.0119</iyy>   <!-- transverse = 1/12*m*(3r²+L²) -->
        <iyz>0.0</iyz>
        <izz>0.0119</izz>
      </inertia>
    </inertial>
    <visual name="lr_wheel_visual">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.15 0.15 0.15 1</diffuse>
      </material>
    </visual>
    <collision name="lr_wheel_collision">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <!-- front right wheel -->
  <link name="right_front_wheel">
    <pose>0 0 0  1.5708 0 0</pose>
    <inertial>
      <mass>2.0</mass>
      <inertia>
        <ixx>0.0225</ixx>   <!-- around rotation axis = 1/2*m*r² -->
        <ixy>0.0</ixy>
        <ixz>0.0</ixz>
        <iyy>0.0119</iyy>   <!-- transverse = 1/12*m*(3r²+L²) -->
        <iyz>0.0</iyz>
        <izz>0.0119</izz>
      </inertia>
    </inertial>
    <visual name="rf_wheel_visual">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.15 0.15 0.15 1</diffuse>
      </material>
    </visual>
    <collision name="rf_wheel_collision">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <!-- rear right wheel -->
  <link name="right_rear_wheel">
    <pose>0 0 0  1.5708 0 0</pose>
    <inertial>
      <mass>2.0</mass>
      <inertia>
        <ixx>0.0225</ixx>   <!-- around rotation axis = 1/2*m*r² -->
        <ixy>0.0</ixy>
        <ixz>0.0</ixz>
        <iyy>0.0119</iyy>   <!-- transverse = 1/12*m*(3r²+L²) -->
        <iyz>0.0</iyz>
        <izz>0.0119</izz>
      </inertia>
    </inertial>
    <visual name="rr_wheel_visual">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.15 0.15 0.15 1</diffuse>
      </material>
    </visual>
    <collision name="rr_wheel_collision">
      <geometry>
        <cylinder>
          <radius>0.15</radius>
          <length>0.06</length>
        </cylinder>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>

  <!-- front-left joint -->
  <joint name="left_front_joint" type="revolute">
    <parent>base_link</parent>
    <child>left_front_wheel</child>
    <pose>0.45 0.325 0.15  0 0 0</pose>
    <axis>
      <xyz>0 1 0</xyz>
      <limit>
        <lower>-1e16</lower>
        <upper>1e16</upper>
      </limit>
    </axis>
  </joint>

  <!-- rear-left joint -->
  <joint name="left_rear_joint" type="revolute">
    <parent>base_link</parent>
    <child>left_rear_wheel</child>
    <pose>-0.45 0.325 0.15  0 0 0</pose>
    <axis>
      <xyz>0 1 0</xyz>
      <limit>
        <lower>-1e16</lower>
        <upper>1e16</upper>
      </limit>
    </axis>
  </joint>

  <!-- front-right joint -->
  <joint name="right_front_joint" type="revolute">
    <parent>base_link</parent>
    <child>right_front_wheel</child>
    <pose>0.45 -0.325 0.15  0 0 0</pose>
    <axis>
      <xyz>0 1 0</xyz>
      <limit>
        <lower>-1e16</lower>
        <upper>1e16</upper>
      </limit>
    </axis>
  </joint>

  <!-- rear-right joint -->
  <joint name="right_rear_joint" type="revolute">
    <parent>base_link</parent>
    <child>right_rear_wheel</child>
    <pose>-0.45 -0.325 0.15  0 0 0</pose>
    <axis>
      <xyz>0 1 0</xyz>
      <limit>
        <lower>-1e16</lower>
        <upper>1e16</upper>
      </limit>
    </axis>
  </joint>

  <!-- ============================================================ -->
  <!-- Plugins                                                        -->
  <!-- ============================================================ -->

  <!-- DiffDrive: left wheels + right wheels driven together -->
  <plugin
    filename="gz-sim-diff-drive-system"
    name="gz::sim::systems::DiffDrive">
    <left_joint>left_front_joint</left_joint>
    <right_joint>right_front_joint</right_joint>
    <wheel_separation>0.65</wheel_separation>
    <wheel_radius>0.15</wheel_radius>
    <max_linear_acceleration>2.0</max_linear_acceleration>
    <max_angular_acceleration>2.0</max_angular_acceleration>
    <odom_publish_frequency>50.0</odom_publish_frequency>
  </plugin>

  <!-- JointStatePublisher: publish all joint states -->
  <plugin
    filename="gz-sim-joint-state-publisher-system"
    name="gz::sim::systems::JointStatePublisher">
    <joint_name>left_front_joint</joint_name>
    <joint_name>left_rear_joint</joint_name>
    <joint_name>right_front_joint</joint_name>
    <joint_name>right_rear_joint</joint_name>
    <update_rate>50.0</update_rate>
  </plugin>

  <!-- IMU: fixed at base_link origin -->
  <plugin
    filename="gz-sim-imu-system"
    name="gz::sim::systems::Imu">
    <topic>/model/vineyard_mower/imu</topic>
  </plugin>

  <!-- UserCommands: direct keyboard control (bypasses ROS2, works in WSL2) -->
  <plugin
    filename="gz-sim-user-commands-system"
    name="gz::sim::systems::UserCommands">
  </plugin>

</model>
</sdf>
