<?xml version="1.0" encoding="UTF-8"?>
<model>
  <name>Vineyard Mower</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <author>
    <name>Vineyard Mower Team</name>
    <email>dev@vineyardmower.local</email>
  </author>
  <description>
    A 4WD differential-drive autonomous vineyard mowing robot.
    Chassis: 1.2m x 0.8m x 0.4m, 250kg.
    4 individually-driven wheels (r=0.15m), wheelbase=0.9m, track=0.65m.
    Equipped with DiffDrive, JointStatePublisher, and IMU plugins.
  </description>
</model>
